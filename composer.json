{
    "name": "netmafia/netmafia",
    "description": "Modern NetMafia Game Engine",
    "type": "project",
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "php-di/php-di": "^7.0",
        "twig/twig": "^3.0",
        "doctrine/dbal": "^3.0",
        "vlucas/phpdotenv": "^5.0",
        "slim/csrf": "^1.0",
        "cboden/ratchet": "^0.4",
        "slim/twig-view": "^3.4",
        "robmorgan/phinx": "^0.16.10",
        "predis/predis": "^3.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0",
        "symfony/var-dumper": "^6.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Netmafia\\": "src/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse --no-progress",
        "stan": "@analyse",
        "websocket": "php bin/server.php",
        "check": [
            "@analyse"
        ]
    },
    "scripts-descriptions": {
        "analyse": "PHPStan statikus kód analízis futtatása",
        "websocket": "WebSocket szerver indítása",
        "check": "Összes ellenőrzés futtatása"
    },
    "authors": [
        {
            "name": "Netmafia Team"
        }
    ]
}
