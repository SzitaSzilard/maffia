{% extends is_ajax ? "layouts/ajax.twig" : "layouts/base_game.twig" %}

{% block content %}
<style>
    .street-container {
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
        border: 1px solid #000;
        background: #e0e0e0;
        font-family: Arial, sans-serif;
    }

    .street-image-container {
        width: 100%;
        border-bottom: 1px solid #000;
    }

    .street-image {
        width: 100%;
        height: auto;
        display: block;
    }

    .car-table {
        width: 100%;
        border-collapse: collapse;
    }

    .car-table th {
        background: #fff;
        color: #000;
        font-weight: bold;
        text-align: left;
        padding: 5px 10px;
        border-bottom: 1px solid #000;
        border-right: 1px solid #000;
        font-size: 14px;
    }

    .car-table th:last-child {
        border-right: none;
        width: 100px;
    }

    .car-row {
        background: #e0e0e0;
        border-bottom: 1px solid #000;
    }

    .car-row:last-child {
        border-bottom: none;
    }

    .car-cell {
        padding: 5px 10px;
        border-right: 1px solid #000;
        font-size: 12px;
        vertical-align: middle;
    }

    .car-cell:last-child {
        border-right: none;
    }

    .car-link {
        color: #555;
        text-decoration: underline;
        font-weight: bold;
        cursor: pointer;
        background: none;
        border: none;
        padding: 0;
        font-size: 12px;
        font-family: Arial, sans-serif;
    }

    .car-link:hover {
        color: #000;
    }

    .car-link-disabled {
        color: #999;
        text-decoration: none;
        font-weight: bold;
        cursor: not-allowed;
        background: none;
        border: none;
        padding: 0;
        font-size: 12px;
        font-family: Arial, sans-serif;
    }

    .empty-message {
        padding: 20px;
        text-align: center;
        font-weight: bold;
        font-size: 14px;
    }


    .cooldown-notice {
        padding: 8px 10px;
        background: #333;
        color: #ff8800;
        text-align: center;
        font-size: 13px;
        border-bottom: 1px solid #000;
    }
    .cooldown-notice svg {
        width: 14px;
        height: 14px;
        vertical-align: middle;
        margin-right: 5px;
        fill: #ff8800;
    }

    .attempts-info {
        padding: 5px 10px;
        background: #ddd;
        color: #555;
        font-size: 11px;
        text-align: right;
        border-bottom: 1px solid #000;
    }
</style>

<div class="p-10" style="background:#e0e0e0;">


    <div class="street-container">
        
        <div class="street-image-container">
            <img src="/images/dealership.jpg" alt="Dealership" class="street-image" style="background:#999; height:250px; object-fit:cover;">
        </div>

        {% if has_cooldown %}
            <div class="cooldown-notice" id="dealership-cooldown-bar" data-cooldown-ts="{{ cooldown_until_ts }}">
                <svg viewBox="0 0 512 512"><path d="M256,8C119,8,8,119,8,256S119,504,256,504,504,393,504,256,393,8,256,8Zm92.49,313h0l-20,25a16,16,0,0,1-22.49,2.5h0l-67-49.72a40,40,0,0,1-15-31.23V112a16,16,0,0,1,16-16h32a16,16,0,0,1,16,16V256l58,42.5A16,16,0,0,1,348.49,321Z"/></svg>
                Újra próbálkozhatsz: <span id="dealership-cooldown-timer">--:--</span>
            </div>
        {% endif %}

        {% if vehicles|length > 0 %}
            <table class="car-table">
                <thead>
                    <tr>
                        <th></th>
                        <th>Esély:</th>
                    </tr>
                </thead>
                <tbody>
                    {% for v in vehicles %}
                        <tr class="car-row">
                            <td class="car-cell">
                                {% if has_cooldown %}
                                    <span class="car-link-disabled" title="Várakozási idő aktív!">
                                        {{ v.name }}
                                    </span>
                                {% else %}
                                    <form action="/autolopas/szalon" method="POST" style="margin:0;">
                                        {{ csrf.keys|raw }}
                                        <input type="hidden" name="vehicle_id" value="{{ v.id }}">
                                        <button type="submit" class="car-link" title="{{ v.category }} | Sebesség: {{ v.speed }} | Biztonság: {{ v.safety }}">
                                            {{ v.name }}
                                        </button>
                                    </form>
                                {% endif %}
                            </td>
                            <td class="car-cell">{{ v.theft_chance }} %</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="empty-message">
                Sajnos ennek az országnak nincs saját márkás autója! <br><br>
                <a href="/autolopas" class="car-link" hx-boost="true" hx-target="#game-content">(Vissza)</a>
            </div>
        {% endif %}

        {% if vehicles|length > 0 %}
            <div style="padding: 5px 10px; text-align: center;">
                <a href="/autolopas" class="car-link" hx-boost="true" hx-target="#game-content">(Vissza)</a>
            </div>
        {% endif %}
        
    </div>
</div>

{% if has_cooldown %}
<script>
(function() {
    var bar = document.getElementById('dealership-cooldown-bar');
    var timer = document.getElementById('dealership-cooldown-timer');
    if (!bar || !timer) return;

    var targetTs = parseInt(bar.getAttribute('data-cooldown-ts'), 10);

    function tick() {
        var now = window.NetMafia && window.NetMafia.now ? window.NetMafia.now() : Math.floor(Date.now() / 1000);
        var diff = targetTs - now;
        if (diff <= 0) {
            window.location.reload();
            return;
        }
        var m = Math.floor(diff / 60);
        var s = diff % 60;
        timer.textContent = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
    }

    tick();
    setInterval(tick, 1000);
})();
</script>
{% endif %}

{% endblock %}
