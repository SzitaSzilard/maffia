{% extends is_ajax ? "layouts/ajax.twig" : "layouts/base_game.twig" %}

{% block content %}
<style>
    .forum-container {
        font-family: Arial, sans-serif;
        font-size: 11px;
        color: #333;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 10px;
    }

    .forum-table {
        width: 100%;
        border-collapse: collapse;
        border: 1px solid #000;
        background-color: #efefef;
        margin-bottom: 20px;
    }

    .forum-table .table-title {
        background-color: #3d3d3d;
        color: #ffffff;
        text-align: center;
        padding: 6px;
        font-size: 13px;
        font-weight: normal;
    }

    .forum-table .col-headers th {
        background-color: #ffffff;
        color: #000000;
        font-weight: bold;
        padding: 5px;
        border-top: 2px solid #000;
        border-bottom: 3px solid #000;
        text-align: center;
    }

    .forum-table td {
        padding: 6px 4px;
        text-align: center;
        border-bottom: 1px solid #b8b8b8;
        line-height: 1.3;
    }

    .forum-table tr:last-child td {
        border-bottom: none;
    }

    .forum-table .text-left {
        text-align: left;
        padding-left: 10px;
    }

    .forum-table a {
        color: #557593;
        text-decoration: underline;
    }

    .forum-table .desc {
        color: #444;
        font-size: 10px;
        display: block;
        margin-top: 2px;
    }

    .forum-footer-text {
        text-align: center;
        font-size: 11px;
        line-height: 1.4;
        color: #333;
    }
</style>

<div class="forum-container">

    {% include 'forum/_categories.twig' %}

    {# Topic nyitás gomb / form #}
    {% set canCreateTopic = user.is_admin or not category.is_closed %}
    {% if canCreateTopic %}
    <div style="width: 600px; text-align: right; margin-bottom: 5px;">
        <button class="btn btn-sm btn-light border border-secondary" style="font-size: 11px; padding: 2px 10px; border-radius: 2px; cursor: pointer;"
                onclick="document.getElementById('new-topic-form').style.display = document.getElementById('new-topic-form').style.display === 'none' ? 'block' : 'none';">
            Új topic
        </button>
    </div>

    <div id="new-topic-form" style="display: none; width: 600px; background: #f5f5f5; border: 1px solid #000; padding: 10px; margin-bottom: 10px;">
        <form hx-post="/forum/kategoria/{{ category.id }}/uj-topic" hx-target="#topic-alert" hx-swap="innerHTML">
            {{ csrf.keys|raw }}
            <div style="margin-bottom: 6px;">
                <label style="font-size: 12px; font-weight: bold;">Topic címe:</label>
                <input type="text" name="title" required maxlength="200" style="width: 100%; padding: 4px; border: 1px solid #999; border-radius: 2px; font-size: 13px;">
            </div>
            <div style="margin-bottom: 6px;">
                <label style="font-size: 12px; font-weight: bold;">Első hozzászólás:</label>
                <textarea name="content" required rows="4" style="width: 100%; padding: 4px; border: 1px solid #999; border-radius: 2px; font-size: 13px; resize: vertical;"></textarea>
            </div>
            <button type="submit" class="btn btn-sm btn-light border border-secondary" style="font-size: 12px; padding: 3px 12px; border-radius: 2px;" hx-disabled-elt="this">Létrehozás</button>
        </form>
    </div>
    {% endif %}

    <div id="topic-alert" style="width: 600px;"></div>

    {# Topikok táblázat #}
    <table class="forum-table">
        <thead>
            <tr>
                <th colspan="3" class="table-title">{{ category.name }} {% if category.is_closed %}🔒{% endif %}</th>
            </tr>
            <tr class="col-headers">
                <th style="width: 50%;">Topik:</th>
                <th style="width: 20%;">Üzenetek</th>
                <th style="width: 30%;">Utolsó üzenet</th>
            </tr>
        </thead>
        <tbody>
            {% for topic in topics %}
            <tr>
                <td class="text-left">
                    {% if topic.is_pinned %}📌 {% endif %}
                    {% if topic.is_locked %}🔒 {% endif %}
                    <a href="#" hx-get="/forum/topic/{{ topic.id }}" hx-target="#game-content" hx-push-url="true">{{ topic.title }}</a>

                    {% if user.is_admin %}
                        <div style="font-size: 10px; margin-top: 4px;">
                            <a href="#" style="color: #888;" onclick="var f=document.getElementById('topic-edit-{{ topic.id }}'); f.style.display=f.style.display==='none'?'block':'none'; return false;">[Szerkesztés]</a>
                            <a href="#" style="color: #c00;" onclick="showDeleteModal('Biztosan törlöd ezt a topicot és MINDEN hozzászólását?', 'topic-del-{{ topic.id }}'); return false;">[Törlés]</a>
                            <form id="topic-del-{{ topic.id }}" hx-post="/forum/admin/topic-torles" hx-target="#topic-alert" hx-swap="innerHTML" style="display:none;">
                                {{ csrf.keys|raw }}
                                <input type="hidden" name="id" value="{{ topic.id }}">
                            </form>
                        </div>
                        <div id="topic-edit-{{ topic.id }}" style="display: none; margin-top: 4px; padding: 6px; background: #fff; border: 1px solid #ccc; text-align: left;">
                            <form hx-post="/forum/admin/topic-szerkesztes" hx-target="#topic-alert" hx-swap="innerHTML">
                                {{ csrf.keys|raw }}
                                <input type="hidden" name="id" value="{{ topic.id }}">
                                <input type="text" name="title" value="{{ topic.title }}" style="width: 100%; padding: 3px; border: 1px solid #999; font-size: 12px; margin-bottom: 4px;">
                                <label style="font-size: 11px;"><input type="checkbox" name="is_locked" value="1" {{ topic.is_locked ? 'checked' : '' }}> Zárt</label>
                                <label style="font-size: 11px; margin-left: 8px;"><input type="checkbox" name="is_pinned" value="1" {{ topic.is_pinned ? 'checked' : '' }}> Kitűzött</label>
                                <button type="submit" style="font-size: 11px; padding: 2px 8px; margin-left: 6px;" hx-disabled-elt="this">Mentés</button>
                            </form>
                        </div>
                    {% endif %}
                </td>
                <td>{{ topic.post_count }}</td>
                <td>
                    {% if topic.last_post_at %}
                        {{ topic.last_post_at }}<br>{{ topic.last_post_username }}
                    {% else %}
                        —
                    {% endif %}
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="3" style="padding: 15px;">
                    Még nincs topic ebben a kategóriában.
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {# Statisztikák #}
    <div class="forum-footer-text">
        Összes Topik : {{ stats.total_topics }}<br>
        Összes hozzászólás: {{ stats.total_posts }}
    </div>

    {# Általános törlés modal #}
    <div id="delete-modal" class="modal-overlay" style="display: none; align-items: center; justify-content: center;">
        <div class="modal-box" style="text-align: center; max-width: 400px; width: 90%;">
            <div class="modal-title" style="margin-bottom: 10px; font-weight: bold; font-size: 14px;">🗑️ Törlés megerősítése</div>
            <div id="delete-modal-text" style="color: #555; margin-bottom: 20px; font-size: 13px;"></div>
            <div>
                <button type="button" id="delete-modal-confirm" class="btn btn-sm btn-light border border-secondary" style="margin-right: 10px; color: #c00;">✓ Törlés</button>
                <button type="button" onclick="document.getElementById('delete-modal').style.display='none'" class="btn btn-sm btn-light border border-secondary">✕ Mégse</button>
            </div>
        </div>
    </div>

    <script>
        function showDeleteModal(msg, formId) {
            document.getElementById('delete-modal-text').innerText = msg;
            document.getElementById('delete-modal-confirm').onclick = function() {
                document.getElementById('delete-modal').style.display = 'none';
                document.getElementById(formId).requestSubmit();
            };
            document.getElementById('delete-modal').style.display = 'flex';
        }
    </script>

</div>
{% endblock %}
