                            {% if user.has_oc_cooldown %}
                                <svg title="Várakozási idő aktív" class="menu-cooldown-icon" viewBox="0 0 512 512"><path d="M256,8C119,8,8,119,8,256S119,504,256,504,504,393,504,256,393,8,256,8Zm92.49,313h0l-20,25a16,16,0,0,1-22.49,2.5h0l-67-49.72a40,40,0,0,1-15-31.23V112a16,16,0,0,1,16-16h32a16,16,0,0,1,16,16V256l58,42.5A16,16,0,0,1,348.49,321Z"/></svg>
                                <div class="menu-tooltip">Újra próbálkozhatsz: <span class="cooldown-timer">--:--</span></div>
                            {% endif %}
                        </a>
                    </li>
                    <li><a href="#" hx-get="/megbizasok" hx-target="#game-content" hx-push-url="true">Megbízások</a></li>
                    <li id="car-theft-menu-item" class="menu-item-with-tooltip" data-cooldown-timestamp="{% if user.has_car_theft_cooldown %}{{ (user.car_theft_cooldown_until ~ ' UTC')|date('U') }}{% else %}0{% endif %}">
                        <a href="#" hx-get="/autolopas" hx-target="#game-content" hx-push-url="true">
                            Járműlopás
                            {% if user.has_car_theft_cooldown %}
                                <svg title="Várakozási idő aktív" class="menu-cooldown-icon" viewBox="0 0 512 512"><path d="M256,8C119,8,8,119,8,256S119,504,256,504,504,393,504,256,393,8,256,8Zm92.49,313h0l-20,25a16,16,0,0,1-22.49,2.5h0l-67-49.72a40,40,0,0,1-15-31.23V112a16,16,0,0,1,16-16h32a16,16,0,0,1,16,16V256l58,42.5A16,16,0,0,1,348.49,321Z"/></svg>
                                <div class="menu-tooltip">Újra próbálkozhatsz: <span class="cooldown-timer">--:--</span></div>
                            {% endif %}
                        </a>
                    </li>
                    <li id="ecrime-menu-item" class="menu-item-with-tooltip">
                        <a href="#" hx-get="/e-bunozes" hx-target="#game-content" hx-push-url="true">
                            e-Bűnözés
                            {% if user.has_ecrime_cooldown or user.has_hack_cooldown %}
                                <svg title="Várakozási idő aktív" class="menu-cooldown-icon" viewBox="0 0 512 512"><path d="M256,8C119,8,8,119,8,256S119,504,256,504,504,393,504,256,393,8,256,8Zm92.49,313h0l-20,25a16,16,0,0,1-22.49,2.5h0l-67-49.72a40,40,0,0,1-15-31.23V112a16,16,0,0,1,16-16h32a16,16,0,0,1,16,16V256l58,42.5A16,16,0,0,1,348.49,321Z"/></svg>
                                <div class="menu-tooltip multi-tooltip" style="padding: 6px; white-space: nowrap; width: max-content;">
                                    {% if user.has_ecrime_cooldown %}
                                    <div class="multi-cooldown-row" data-cooldown-timestamp="{{ (user.scam_cooldown_until ~ ' UTC')|date('U') }}">
                                        A következő átverésig várnod kell <span class="cooldown-timer timer-text" style="font-weight: bold; margin-left: 3px;">--:--</span>
                                    </div>
                                    {% endif %}
                                    {% if user.has_hack_cooldown %}
                                    <div class="multi-cooldown-row" data-cooldown-timestamp="{{ (user.virus_dev_cooldown_until ~ ' UTC')|date('U') }}" {% if user.has_ecrime_cooldown %}style="margin-top: 4px; padding-top: 4px; border-top: 1px dotted #ccc;"{% endif %}>
                                        A következő hackelésig/fejlesztésig várnod kell <span class="cooldown-timer timer-text" style="font-weight: bold; margin-left: 3px;">--:--</span>
                                    </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </a>
                    </li>
                    {% set _pc_scan_ts = user.petty_crime_scan_cooldown_until ? (user.petty_crime_scan_cooldown_until ~ ' UTC')|date('U') : 0 %}
                    {% set _pc_commit_ts = user.petty_crime_commit_cooldown_until ? (user.petty_crime_commit_cooldown_until ~ ' UTC')|date('U') : 0 %}
                    <li id="kisstilubunozes-menu-item" class="menu-item-with-tooltip" data-cooldown-timestamp="{{ _pc_scan_ts > _pc_commit_ts ? _pc_scan_ts : _pc_commit_ts }}">
                        <a href="#" hx-get="/kisstilubunozes" hx-target="#game-content" hx-push-url="true">
                            Kisstílű bűnözés
                            {% if user.has_petty_crime_scan_cooldown or user.has_petty_crime_commit_cooldown %}
                                <svg title="Várakozási idő aktív" class="menu-cooldown-icon" viewBox="0 0 512 512"><path d="M256,8C119,8,8,119,8,256S119,504,256,504,504,393,504,256,393,8,256,8Zm92.49,313h0l-20,25a16,16,0,0,1-22.49,2.5h0l-67-49.72a40,40,0,0,1-15-31.23V112a16,16,0,0,1,16-16h32a16,16,0,0,1,16,16V256l58,42.5A16,16,0,0,1,348.49,321Z"/></svg>
                                <div class="menu-tooltip">Újra próbálkozhatsz: <span class="cooldown-timer">--:--</span></div>
                            {% endif %}
                        </a>
                    </li>
                    {% set _weed_cd_ts = user.weed_plant_cooldown_until_ts > user.weed_harvest_cooldown_until_ts ? user.weed_plant_cooldown_until_ts : user.weed_harvest_cooldown_until_ts %}
                    <li id="weed-menu-item" class="menu-item-with-tooltip" data-cooldown-timestamp="{{ _weed_cd_ts }}">
                        <a href="#" hx-get="/vadkender" hx-target="#game-content" hx-push-url="true" {% if user.xp < 600 and not user.is_admin %}style="color: #666;"{% endif %}>
                            Vadkender ültetés
                            {% if user.has_weed_plant_cooldown or user.has_weed_harvest_cooldown %}
                                <svg title="Várakozási idő aktív" class="menu-cooldown-icon" viewBox="0 0 512 512"><path d="M256,8C119,8,8,119,8,256S119,504,256,504,504,393,504,256,393,8,256,8Zm92.49,313h0l-20,25a16,16,0,0,1-22.49,2.5h0l-67-49.72a40,40,0,0,1-15-31.23V112a16,16,0,0,1,16-16h32a16,16,0,0,1,16,16V256l58,42.5A16,16,0,0,1,348.49,321Z"/></svg>
                                <div class="menu-tooltip">
                                    {% if user.has_weed_plant_cooldown %}Következő ültetés:{% else %}Betakarítható:{% endif %}
                                    <span class="cooldown-timer">--:--</span>
                                </div>
                            {% endif %}
                        </a>
                    </li>
                    <li><a href="#" hx-get="/femkereskedelem" hx-target="#game-content" hx-push-url="true">Fémkereskedelem</a></li>
                    <li><a href="#" hx-get="/kakasviadal" hx-target="#game-content" hx-push-url="true">Kakasviadal</a></li>
                    <li><a href="#" hx-get="/oromlany" hx-target="#game-content" hx-push-url="true">Örömlány</a></li>
                    <li><a href="#" hx-get="/boxclub" hx-target="#game-content" hx-push-url="true">Box club</a></li>
                </ul>
                </div>
            </aside>

            <!-- KÖZÉPSŐ TARTALOM -->
            <main class="content">
                <div id="flash-container">
                    {# Server-side flash messages from session (fallback) #}
                    {% if session_flashes is defined %}
                        {% for type, message in session_flashes %}
                            <div class="alert-{{ 'error' in type ? 'error' : 'success' }}">{{ message }}</div>
                        {% endfor %}
                    {% endif %}
                </div>
                
                {# Inner wrapper for HTMX Swaps #}
                <div id="game-content">
                    {% block content %}
                        {% include 'game/dashboard.twig' %}
                    {% endblock %}
                </div>
            </main>

            <!-- JOBB OLDALSÁV -->
            <aside class="sidebar">
                <div class="sidebar-inner">
                    <div class="menu-header">KÖZÖSSÉG</div>
                <ul class="menu-list">
                    <li><a href="#" hx-get="/uzenetek" hx-target="#game-content" hx-push-url="true" onclick="fadeBadge('.unread-badge')">Üzenetek{% if unread_messages > 0 %} <span class="unread-badge menu-badge">({{ unread_messages }})</span>{% endif %}</a></li>
                    <li><a href="#" hx-get="/banda" hx-target="#game-content" hx-push-url="true">Banda</a></li>
                    <li><a href="#" hx-get="/online-gengszterek" hx-target="#game-content" hx-push-url="true">Online Gengszterek</a></li>
                    <li><a href="#" hx-get="/forum" hx-target="#game-content" hx-push-url="true">Fórum</a></li>
                    <li><a href="#" hx-get="/kocsma" hx-target="#game-content" hx-push-url="true">Kocsma <span class="menu-badge">(!)</span></a></li>
                    <li><a href="#" hx-get="/helpdesk" hx-target="#game-content" hx-push-url="true">Helpdesk</a></li>
                    <li><a href="#" hx-get="/gengszter-kereses" hx-target="#game-content" hx-push-url="true">Gengszter keresés</a></li>
                    <li><a href="#" hx-get="/oldal-ajanlasa" hx-target="#game-content" hx-push-url="true">Oldal ajánlása</a></li>
                </ul>

                <div class="menu-header">JÁRMŰVEK</div>
                <ul class="menu-list">
                    <li><a href="#" hx-get="/garazs" hx-target="#game-content" hx-push-url="true">Garázs</a></li>
                    <li><a href="#" hx-get="/versenyzes" hx-target="#game-content" hx-push-url="true">Versenyzés</a></li>
                    <li><a href="#" hx-get="/gyakorlopalya" hx-target="#game-content" hx-push-url="true">Gyakorlópálya</a></li>
                    <li><a href="#" hx-get="/szalonok" hx-target="#game-content" hx-push-url="true">Szalonok</a></li>
                    <li><a href="#" hx-get="/benzinkut" hx-target="#game-content" hx-push-url="true">Benzinkút</a></li>
                </ul>

                <div class="menu-header">KASZINÓ</div>
                <ul class="menu-list">
                    <li><a href="#" hx-get="/poker" hx-target="#game-content" hx-push-url="true">Póker</a></li>
                    <li><a href="#" hx-get="/kaparos-sorsjegy" hx-target="#game-content" hx-push-url="true">Kaparós sorsjegy</a></li>
                    <li><a href="#" hx-get="/felkaru-rablo" hx-target="#game-content" hx-push-url="true">Félkarú rabló</a></li>
                    <li><a href="#" hx-get="/blackjack" hx-target="#game-content" hx-push-url="true">Blackjack</a></li>
                    <li><a href="#" hx-get="/lotto" hx-target="#game-content" hx-push-url="true">Lottó</a></li>
                    <li><a href="#" hx-get="/sportfogadas" hx-target="#game-content" hx-push-url="true">Sportfogadás</a></li>
                </ul>

                <div class="menu-header">PROFILOD</div>
                <ul class="menu-list">
                    <li><a href="#" hx-get="/beallitasok" hx-target="#game-content" hx-push-url="true">Beállítások</a></li>
                    <li><a href="#" hx-get="/baratok" hx-target="#game-content" hx-push-url="true">Barátok szerkesztése</a></li>
                    <li><a href="#" hx-get="/statisztikak" hx-target="#game-content" hx-push-url="true">Statisztikád</a></li>
                    <li><a href="#" hx-get="/game" hx-target="#game-content" hx-push-url="true">Főoldal</a></li>
                    <li><a href="#" hx-get="/szabalyzat" hx-target="#game-content" hx-push-url="true">Szabályzat</a></li>
                    <li><a href="#" hx-get="/gyik" hx-target="#game-content" hx-push-url="true">Gyik</a></li>
                    <li>
                        <form action="/logout" method="POST" id="logout-form" class="hidden">
                            {{ csrf.keys|raw }}
                        </form>
                        <a href="#" onclick="document.getElementById('logout-form').submit(); return false;">Kijelentkezés</a>
                    </li>
                </ul>
                </div>
            </aside>

        </div>
    </div>

</body>

</html>
