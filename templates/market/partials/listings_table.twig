<style>
    .market-table {
        width: 100% !important;
        border-collapse: collapse !important;
        background: #eee !important;
        border: 1px solid #000 !important;
        margin-bottom: 0px !important;
    }
    .market-table-header {
        background: #333 !important;
        color: #dcb37b !important;
        text-align: center !important;
        padding: 5px !important;
        font-weight: bold !important;
        font-size: 16px !important;
        border: 1px solid #000 !important;
        border-bottom: none !important;
        margin-top: 15px !important;
    }
    .market-table th, .market-table td {
        border: 1px solid #555 !important;
        padding: 4px 8px !important;
        text-align: left !important;
        font-size: 13px !important;
        vertical-align: middle !important;
        color: #000 !important;
    }
    .market-table th {
        background: #fff !important;
        font-weight: bold !important;
        color: #000 !important;
    }
    .market-table tr:nth-child(even) td { background: #e6e6e6 !important; }
    .market-table tr:nth-child(odd) td { background: #cfcfcf !important; }
    .market-table th .fa-sort {
        float: right !important;
        margin-top: 3px !important;
        color: #000 !important;
    }
    .item-name-col { font-style: italic !important; font-weight: bold !important; }
    
    /* Üres lenyíló cellák elrejtése a táblázat alján lévő dupla vonal kiküszöbölésére */
    td[id^="sellers-"]:empty {
        border: none !important;
        padding: 0 !important;
        height: 0 !important;
    }
    .vehicle-name-col { font-style: italic !important; font-weight: bold !important; color: #1e5a22 !important; }
</style>

{% set vehicleCategories = {
    'veteran': 'Veterán', 'sport': 'Sport', 'suv': 'Terepjáró', 'average': 'Átlag', 
    'motor': 'Motor', 'sedan': 'Sedan', 'other': 'Egyéb', 'luxury': 'Luxus', 'muscle': 'Izomautó'
} %}
{% set vehicleOrigins = {
    'US': 'Usa', 'IT': 'Olasz', 'JP': 'Japán', 'DE': 'Német', 'FR': 'Francia', 'GB': 'Angol', 'RU': 'Orosz', 'SE': 'Svéd'
} %}

<div class="market-table-header text-white">
    {% if category in ['weapon'] %}
        Eladó fegyverek
    {% elseif category == 'armor' %}
        Eladó védelmi eszközök
    {% elseif category == 'consumable' %}
        Eladó elfogyasztható cuccok
    {% elseif category == 'vehicle' %}
        Eladó járművek
    {% elseif category == 'car_part' %}
        Eladó autóalkatrészek
    {% elseif category == 'bullet' %}
        Eladó töltények
    {% elseif category == 'credit' %}
        Eladó kreditek
    {% elseif category == 'misc' %}
        Eladó egyéb cuccok
    {% else %}
        Eladó tárgyak
    {% endif %}
</div>

{% if category in ['misc', 'car_part'] %}
    <div style="background: #eee !important; color: #000 !important; padding: 20px !important; text-align: center !important; border: 1px solid #000 !important; font-weight: bold !important; font-size: 16px !important;">
        Hamarosan!!!
    </div>
{% elseif listings is empty %}
    <div style="background: #eee !important; color: #000 !important; padding: 20px !important; text-align: center !important; border: 1px solid #000 !important; font-size: 13px !important;">
        Jelenleg nincs eladó tárgy ebben a kategóriában.
    </div>
{% elseif category in ['bullet', 'credit'] %}
    <table class="market-table">
        <thead>
            <tr>
                <th>Darabár <i class="fa fa-sort"></i></th>
                <th>Készlet <i class="fa fa-sort"></i></th>
                <th>Eladó <i class="fa fa-sort"></i></th>
                <th>Vétel <i class="fa fa-sort"></i></th>
            </tr>
        </thead>
        <tbody>
            {% for item in listings %}
            <tr>
                <td style="font-weight: bold !important;">
                    {% if item.currency == 'credit' %}
                        {{ item.price|number_format(0, '.', ',') }} Kredit
                    {% else %}
                        ${{ item.price|number_format(0, '.', ',') }}
                    {% endif %}
                </td>
                <td>{{ item.quantity }} db</td>
                <td><a href="/profil/{{ item.seller_name }}" style="color: #333 !important; text-decoration: none !important;">{{ item.seller_name }}</a></td>
                <td>
                    <form hx-post="/piac/vasarlas/{{ item.market_id }}" hx-target="this" hx-swap="outerHTML" style="margin: 0 !important; display: flex !important; align-items: center !important; gap: 4px !important;" hx-disabled-elt="button[type='submit']">
                        {{ csrf.keys|raw }}
                        <input type="number" name="quantity" value="1" min="1" max="{{ item.quantity }}" style="width: 45px !important; text-align: center !important; padding: 1px !important; border: 1px solid #aaa !important; color: #000 !important; background: #fff !important; font-size: 12px !important; height: 18px !important;">
                        <span style="color: #333 !important; font-size: 12px !important;">db</span>
                        <button type="submit" style="background: #f0f0f0 !important; border: 1px solid #aaa !important; padding: 1px 6px !important; cursor: pointer !important; color: #000 !important; font-size: 12px !important; height: 22px !important; font-family: Arial, sans-serif !important;">Megveszem</button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% if category == 'credit' %}
        <div style="text-align: center !important; padding: 10px !important; font-size: 13px !important; color: #333 !important;">
            A kredit ára <strong>DARABÁR</strong>, nem csomag!
        </div>
    {% endif %}
{% else %}
    <table class="market-table">
        <thead>
            <tr>
                {% if category == 'vehicle' %}
                    <th>Jármű <i class="fa fa-sort"></i></th>
                    <th>Kategória <i class="fa fa-sort"></i></th>
                    <th>Alap gyorsaság <i class="fa fa-sort"></i></th>
                    <th>Alap biztonság <i class="fa fa-sort"></i></th>
                    <th>Származás <i class="fa fa-sort"></i></th>
                {% elseif category == 'consumable' %}
                    <th>Elfogyasztható cucc <i class="fa fa-sort"></i></th>
                    <th>Hatása <i class="fa fa-sort"></i></th>
                {% else %}
                    <th>{% if category == 'armor' %}Védelmi eszköz{% else %}Fegyver{% endif %} <i class="fa fa-sort"></i></th>
                    <th>Támadás <i class="fa fa-sort"></i></th>
                    <th>Védelem <i class="fa fa-sort"></i></th>
                {% endif %}
                <th>Eladók száma <i class="fa fa-sort"></i></th>
            </tr>
        </thead>
        <tbody>
            {% for item in listings %}
                <tr style="cursor: pointer;" hx-on:click="let tgt = document.getElementById('sellers-{{ item.item_id }}'); if(tgt && tgt.innerHTML.trim() !== ''){ tgt.innerHTML = ''; } else { htmx.ajax('GET', '/piac/lista/{{ category }}/{{ item.item_id }}', {target: '#sellers-{{ item.item_id }}', swap: 'innerHTML'}); }">
                    {% if category == 'vehicle' %}
                        <td class="vehicle-name-col">{{ item.item_name }}</td>
                        <td>{{ vehicleCategories[item.sub_category] ?? item.sub_category|capitalize }}</td>
                        <td>{{ item.speed }}</td>
                        <td>{{ item.safety }}</td>
                        <td>{{ vehicleOrigins[item.origin_country] ?? item.origin_country }}</td>
                    {% elseif category == 'consumable' %}
                        <td class="item-name-col">{{ item.item_name }}</td>
                        <td>{{ item.description }}</td>
                    {% else %}
                        <td class="item-name-col">{{ item.item_name }}</td>
                        <td>{{ item.attack ?? '-' }}</td>
                        <td>{{ item.defense ?? '-' }}</td>
                    {% endif %}
                    <td>{{ item.seller_count }}</td>
                </tr>
                <tr style="background-color: #eee;">
                    {% set colspan = 4 %}
                    {% if category == 'vehicle' %}{% set colspan = 6 %}
                    {% elseif category == 'consumable' %}{% set colspan = 3 %}
                    {% endif %}
                    <td colspan="{{ colspan }}" style="padding: 0; border: none;" id="sellers-{{ item.item_id }}"></td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endif %}
