<fieldset class="border border-secondary p-3 mb-4 mt-3 mx-auto" style="max-width: 600px; background-color: #e5e5e5; border-radius: 2px;">
    <legend class="float-none w-auto px-2 mb-0" style="font-size: 14px; font-weight: bold; color: #333;">{{ itemName }}</legend>

    <form hx-post="/piac/eladas/bekuld" hx-target="#alert-container" hx-swap="innerHTML">
        {{ csrf.keys|raw }}
        <input type="hidden" name="category" value="{{ category }}">
        <input type="hidden" name="item_id" value="{{ itemId }}">
        
        <div class="d-flex align-items-center mb-3 mt-2 gap-2">
            <label for="quantity" style="font-size: 14px;">Hány darabot szeretnél eladni?</label>
            <input type="number" name="quantity" id="quantity" class="form-control form-control-sm text-center" style="width: 80px; border: 1px solid #999; border-radius: 2px;" min="1" max="{{ maxQuantity }}" value="1" required>
            <span style="font-size: 13px; color: #555;">(Max: {{ maxQuantity }})</span>
        </div>

        <div class="mb-4">
            <div class="d-flex align-items-center gap-2 mb-2">
                <label for="price" class="fw-bold" style="font-size: 14px;">Darabár:</label>
                <div class="input-group input-group-sm" style="width: 180px;">
                    <span class="input-group-text bg-light" style="border: 1px solid #999; border-right: 0;">$</span>
                    <input type="number" name="price" id="price" class="form-control" style="border: 1px solid #999;" required min="1">
                </div>
            </div>
            
            <div class="d-flex align-items-center gap-4 ms-1">
                <div class="form-check d-flex align-items-center gap-2 m-0">
                    <input class="form-check-input mt-0" type="radio" name="currency" id="currency_credit" value="credit" checked>
                    <label class="form-check-label" for="currency_credit" style="font-size: 14px;">Kredit</label>
                </div>
                
                <div class="form-check d-flex align-items-center gap-2 m-0">
                    <input class="form-check-input mt-0" type="radio" name="currency" id="currency_money" value="money">
                    <label class="form-check-label" for="currency_money" style="font-size: 14px;">Pénz</label>
                </div>
            </div>
        </div>

        <div class="text-center mt-4">
            <button type="submit" class="btn btn-light border border-secondary px-4 py-1 fw-bold fs-6" style="border-radius: 2px;" hx-disabled-elt="this">Mehet</button>
        </div>
    </form>
</fieldset>

