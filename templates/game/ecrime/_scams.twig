{% if not user.has_laptop %}
    <div style="text-align: center; margin: 60px 20px; font-size: 13px; color: #444; font-family: 'Inter', 'Segoe UI', sans-serif; letter-spacing: 0.5px;">
        a lehetőségek eléréséhez kérjük, vásárolj egy számítógépet a boltban.
    </div>
{% else %}
<div class="mod-content-box" id="ecrime-bottom-box">
    <div class="mod-box-header">Átverések</div>
    
    {% if global_error %}
        <div class="alert-error" style="margin: 10px;">{{ global_error }}</div>
    {% endif %}
    
    {% if result %}
        <div class="{% if result.success %}alert-success{% else %}alert-error{% endif %}" style="margin: 10px;">
            <strong>{% if result.success %}SIKERES AKCIÓ{% else %}ELBUKTAD{% endif %}</strong><br>
            {{ result.message }}{% if result.success %}, ezzel kerestél ${{ result.money_gained|number_format(0, ',', '.') }}-t.{% endif %}<br>
        </div>
    {% endif %}


    <form method="POST" action="/e-bunozes/atveres-vegrehajtas" style="margin: 0;">
        {{ csrf.keys|raw }}
        <table class="mod-action-table">
            <thead>
                <tr>
                    <th>Módszer</th>
                    <th class="chance-col">Esély</th>
                </tr>
            </thead>
            <tbody>
                {% for scam in scams %}
                <tr>
                    <td>
                        <label>
                            <input type="radio" name="scam_type" value="{{ scam.id }}" required {% if cooldown_remaining > 0 or (scam.id == 4 and not webserver_active) %}disabled{% endif %}>
                            {{ scam.name }}
                        </label>
                    </td>
                    <td class="chance-col">{{ scam.success_chance }}%</td>
                </tr>
                {% endfor %}
                <tr class="mod-button-row">
                    <td colspan="2">
                        {% if cooldown_remaining > 0 %}
                            {# COOLDOWN AKTÍV #}
                            A következő átverésig még várnod kell <span id="scam-timer" style="color:#d32f2f; font-weight:bold;">számítás...</span>
                            
                            <script>
                            (function() {
                                let targetTs = {{ cooldown_target }};
                                
                                function formatSidebar(secs) {
                                    var m = Math.floor(secs / 60);
                                    var s = secs % 60;
                                    var h = Math.floor(m / 60);
                                    m = m % 60;
                                    var f = '';
                                    if (h > 0) f += h + ':';
                                    f += (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
                                    return f;
                                }
                                
                                function syncSidebar(secs) {
                                    var sidebarItem = document.getElementById('ecrime-menu-item');
                                    if (!sidebarItem) return;
                                    sidebarItem.setAttribute('data-cooldown-timestamp', targetTs);
                                    var sidebarTimer = sidebarItem.querySelector('.cooldown-timer');
                                    if (sidebarTimer) {
                                        sidebarTimer.textContent = formatSidebar(secs);
                                    }
                                }
                                
                                function updateTimer() {
                                    const timerEl = document.getElementById('scam-timer');
                                    if (!timerEl) return;

                                    let now = (window.NetMafia && typeof window.NetMafia.now === 'function') 
                                              ? window.NetMafia.now() 
                                              : Math.floor(Date.now() / 1000);
                                    let remaining = targetTs - now;

                                    if (remaining <= 0) {
                                        timerEl.textContent = 'Indulhat!';
                                        timerEl.style.color = '#388e3c';
                                        syncSidebar(0);
                                        setTimeout(() => window.location.reload(), 1000);
                                        return;
                                    }
                                    const m = Math.floor(remaining / 60);
                                    const s = remaining % 60;
                                    timerEl.textContent = m + ' perc ' + (s < 10 ? '0' : '') + s + ' másodpercet';
                                    syncSidebar(remaining);
                                    window.ecrimeTimer = setTimeout(updateTimer, 1000);
                                }
                                if (window.ecrimeTimer) clearTimeout(window.ecrimeTimer);
                                updateTimer();
                            })();
                            </script>
                        {% else %}
                            {# NINCS COOLDOWN #}
                            <button type="submit" class="mod-submit-btn" hx-disabled-elt="this">Elkövetés</button>
                        {% endif %}
                    </td>
                </tr>
            </tbody>
        </table>
    </form>
</div>
{% endif %}

{# ============================================================
   OOB SIDEBAR SZINKRON — minden HTMX betöltésnél frissíti
   az #ecrime-menu-item data-cooldown-timestamp értékét,
   hogy a bal menü tooltip ne csússzon el a főablakhoz képest.
   ============================================================ #}
{% if is_ajax %}
<li id="ecrime-menu-item" class="menu-item-with-tooltip" hx-swap-oob="true">
    <a href="#" hx-get="/e-bunozes" hx-target="#game-content" hx-push-url="true">
        e-Bűnözés
        {% if user.has_ecrime_cooldown or user.has_hack_cooldown %}
            <svg title="Várakozási idő aktív" class="menu-cooldown-icon" viewBox="0 0 512 512"><path d="M256,8C119,8,8,119,8,256S119,504,256,504,504,393,504,256,393,8,256,8Zm92.49,313h0l-20,25a16,16,0,0,1-22.49,2.5h0l-67-49.72a40,40,0,0,1-15-31.23V112a16,16,0,0,1,16-16h32a16,16,0,0,1,16,16V256l58,42.5A16,16,0,0,1,348.49,321Z"/></svg>
            <div class="menu-tooltip multi-tooltip" style="padding: 6px; white-space: nowrap; width: max-content;">
                {% if user.has_ecrime_cooldown %}
                <div class="multi-cooldown-row" data-cooldown-timestamp="{{ (user.scam_cooldown_until ~ ' UTC')|date('U') }}">
                    A következő átverésig várnod kell <span class="cooldown-timer timer-text" style="font-weight: bold; margin-left: 3px;">--:--</span>
                </div>
                {% endif %}
                {% if user.has_hack_cooldown %}
                <div class="multi-cooldown-row" data-cooldown-timestamp="{{ (user.virus_dev_cooldown_until ~ ' UTC')|date('U') }}" {% if user.has_ecrime_cooldown %}style="margin-top: 4px; padding-top: 4px; border-top: 1px dotted #ccc;"{% endif %}>
                    A következő hackelésig/fejlesztésig várnod kell <span class="cooldown-timer timer-text" style="font-weight: bold; margin-left: 3px;">--:--</span>
                </div>
                {% endif %}
            </div>
        {% endif %}
    </a>
</li>
{% endif %}
