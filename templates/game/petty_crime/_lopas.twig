<style>
/* Fő konténer méretezése kártya alapon - CSAK A SOROK / GOMBOK DÍSZÍTÉSE MARADT! */
.pc-image-container {
    width: 100%;
    height: 250px; 
    border-bottom: 1px solid #111;
    overflow: hidden;
    background-color: #ccc;
}

.pc-image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.pc-description {
    padding: 15px;
    font-size: 13px;
    color: #222;
    line-height: 1.4;
    border-bottom: 1px solid #111;
    background-color: #eee;
    text-align: justify;
}

.pc-targets-section {
    background-color: #f4f4f4;
    padding-bottom: 15px;
}

.pc-targets-header {
    text-align: center;
    padding: 12px 0 8px 0;
    font-size: 13px;
    color: #333;
    font-weight: bold;
}

.pc-target-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 15px;
}

.pc-target-row.alt {
    background-color: #e4e4e4;
}

.pc-target-info {
    flex-grow: 1;
}

.pc-target-name {
    font-weight: bold;
    font-size: 13px;
    color: #333;
    margin-bottom: 2px;
}

.pc-target-desc {
    font-style: italic;
    font-size: 12px;
    color: #444;
    margin-bottom: 2px;
}

.pc-target-chance {
    font-size: 13px;
    color: #333;
}

.pc-action-btn {
    background-color: #f0f0f0;
    border: 1px solid #777;
    padding: 5px 12px;
    font-size: 13px;
    color: #000;
    cursor: pointer;
    font-family: inherit;
    font-weight: bold;
    width: auto !important;
    display: inline-block !important;
}

.pc-action-btn:hover:not(:disabled) {
    background-color: #e0e0e0;
}

.pc-action-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.pc-timer-line {
    font-size: 13px;
    color: #444;
    text-align: center;
    padding: 10px 0;
}
</style>

<div class="mod-content-box" style="padding:0; overflow:hidden;">
    <div class="mod-box-header">Lopás</div>
    
    <div class="pc-image-container">
        <img src="https://images.unsplash.com/photo-1620002167735-90180ce873ab?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Lopás">
    </div>

    <div class="pc-description">
        Tökéletes helyen jársz, ha el szeretnéd kezdeni a gengszter pályafutásodat. Itt lehetőséged nyílik még fegyver nélkül és nagyobb kockázat nélkül kisebb-nagyobb összeget bezsebelned, mielőtt komolyabb szintre lépsz a karrieredben.<br><br>
        A feladatod így az elején még nagyon egyszerű – csak térképezd fel a környéket, majd válassz egyet a lehetséges célpontok közül.
    </div>

    {# ================= EREDMÉNYEK (FLASHEK) ================= #}
    {% if global_error %}
        <div class="alert-error" style="margin: 10px 15px;">{{ global_error }}</div>
    {% endif %}

    {% if result is defined and result %}
        <div class="{% if result.success %}alert-success{% else %}alert-error{% endif %}" style="margin: 10px 15px;">
            <strong>{% if result.success %}✓ SIKERES AKCIÓ{% else %}✗ ELBUKTAD{% endif %}</strong><br>
            {{ result.crime_name }}{% if result.success %}, ezzel kerestél <strong>${{ result.money_gained|number_format(0, ',', '.') }}</strong>-t.{% endif %}<br>
        </div>
    {% endif %}

    {# ================= COOLDOWN & KERESÉS ================= #}
    {% set active_target = commit_target > scan_target ? commit_target : scan_target %}
    {% set active_remaining = commit_remaining > scan_remaining ? commit_remaining : scan_remaining %}

    <div style="text-align: center; border-bottom: 1px solid #ccc; background: #eee; padding: 15px;">
        {% if active_remaining > 0 %}
            <div class="pc-timer-line" style="margin-bottom: 5px;">
                Következő próbálkozás:<br>
                <span id="pc-main-timer" style="color: #d32f2f; font-weight: bold; font-size: 15px;">számítás...</span>
            </div>
            <button class="pc-action-btn" disabled style="width: max-content !important; max-width: 250px; display: inline-block; padding: 6px 24px; margin: 0 auto;">Környék feltérképezése</button>
            <script>
            (function() {
                let targetTs = {{ active_target }};
                function updateMainTimer() {
                    const el = document.getElementById('pc-main-timer');
                    if (!el) return;
                    let now = (window.NetMafia && typeof window.NetMafia.now === 'function')
                              ? window.NetMafia.now()
                              : Math.floor(Date.now() / 1000);
                    let rem = targetTs - now;
                    if (rem <= 0) {
                        el.textContent = 'Indulhat!';
                        el.style.color = '#388e3c';
                        setTimeout(() => window.location.reload(), 1000);
                        return;
                    }
                    const m = Math.floor(rem / 60);
                    const s = rem % 60;
                    el.textContent = m + ' perc ' + (s < 10 ? '0' : '') + s + ' másodperc';
                    window.pcMainTimer = setTimeout(updateMainTimer, 1000);
                }
                if (window.pcMainTimer) clearTimeout(window.pcMainTimer);
                updateMainTimer();
            })();
            </script>
        {% else %}
            <form method="POST" action="/kisstilubunozes/felterkepez" style="margin:0; text-align:center;">
                {{ csrf.keys|raw }}
                <button type="submit" class="pc-action-btn" hx-disabled-elt="this" style="width: max-content !important; max-width: 250px; display: inline-block; padding: 6px 24px; margin: 0 auto;">
                    Környék feltérképezése
                </button>
            </form>
        {% endif %}
    </div>

    {# ================= LEHETŐSÉGEK ================= #}
    {% if opportunities is not empty %}
    <div class="pc-targets-section">
        <div class="pc-targets-header">
            {{ opportunities|length }} lehetséges célpontot találtál a környéken:
        </div>

        {% set commit_locked = commit_remaining > 0 %}

        {% for opp in opportunities %}
        <div class="pc-target-row {% if loop.index0 % 2 == 1 %}alt{% endif %}">
            <div class="pc-target-info">
                <div class="pc-target-name">{{ opp.name }}</div>
                <div class="pc-target-desc">Nehézség: {{ opp.level_name }} | Energia: {{ opp.energy_cost }}</div>
                <div class="pc-target-chance">Esély: {{ opp.chance }}%</div>
            </div>
            <div class="pc-target-action">
                <form method="POST" action="/kisstilubunozes/elkovet" style="margin:0;">
                    {{ csrf.keys|raw }}
                    <input type="hidden" name="crime_id" value="{{ opp.crime_id }}">
                    <button type="submit" class="pc-action-btn" hx-disabled-elt="this"
                        {% if commit_locked %}disabled{% endif %}>
                        Elkövet
                    </button>
                </form>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

</div>

{# ================= OOB SIDEBAR SZINKRON ================= #}
{% if is_ajax %}
<li id="kisstilubunozes-menu-item"
    class="menu-item-with-tooltip"
    data-cooldown-timestamp="{{ commit_target > scan_target ? commit_target : scan_target }}"
    hx-swap-oob="true">
    <a href="#" hx-get="/kisstilubunozes" hx-target="#game-content" hx-push-url="true">
        Kisstílű Bűnözés
        {% if scan_remaining > 0 or commit_remaining > 0 %}
            <svg title="Várakozási idő aktív" class="menu-cooldown-icon" viewBox="0 0 512 512"><path d="M256,8C119,8,8,119,8,256S119,504,256,504,504,393,504,256,393,8,256,8Zm92.49,313h0l-20,25a16,16,0,0,1-22.49,2.5h0l-67-49.72a40,40,0,0,1-15-31.23V112a16,16,0,0,1,16-16h32a16,16,0,0,1,16,16V256l58,42.5A16,16,0,0,1,348.49,321Z"/></svg>
            <div class="menu-tooltip">Cooldown aktív: <span class="cooldown-timer">--:--</span></div>
        {% endif %}
    </a>
</li>
{% endif %}
